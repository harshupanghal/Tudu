@page "/"
<PageTitle>Tudu</PageTitle>

<div class="landing-hero">
    <div class="content">
        <h1 class="hero-title">Tudu</h1>
        <p class="hero-subtitle">
            Minimal. Powerful. Private.<br>
            Organize your life with elegance.
        </p>

        <div class="btn-group-custom">
            <AuthorizeView>
                <Authorized>
                    <a class="btn-custom btn-primary-custom" href="/tasks">
                        <span>Go to My Tasks</span>
                    </a>
                </Authorized>
                <NotAuthorized>
                    <a class="btn-custom btn-outline-custom" href="/auth/login">
                        <span>Login</span>
                    </a>
                    <a class="btn-custom btn-secondary-custom" href="/auth/register">
                        <span>Register</span>
                    </a>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="features">
            <div class="feature">
              
                <p class="feature-text">Private & Secure</p>
            </div>
            <div class="feature">
                
                <p class="feature-text">Fast & Minimal</p>
            </div>
            <div class="feature">
               
                <p class="feature-text">Stay Organized</p>
            </div>
        </div>
    </div>
</div>
