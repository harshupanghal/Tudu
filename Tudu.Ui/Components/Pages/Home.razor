@page "/"
<PageTitle>Tudu</PageTitle>

<div class="landing-hero">
        <div class="content">
            <h1 class="hero-title">Tudu</h1>
            <p class="hero-subtitle">
                Minimal. Powerful. Private.<br>
                Organize your life with elegance.
            </p>

        <div class="btn-group-custom">
    <AuthorizeView>
        <Authorized>
                    <a class="btn-custom btn-primary-custom" href="/tasks">
                Go to My Tasks
            </a>
        </Authorized>
        <NotAuthorized>
            <div class="d-flex gap-3 flex-wrap justify-content-center z-1">
                        <a class="btn-custom btn-outline-custom" href="/auth/login">
                    Login
                </a>
                        <a class="btn-custom btn-secondary-custom" href="/auth/register">
                    Register
                </a>
            </div>
        </NotAuthorized>
    </AuthorizeView>
    </div>
        <div class="features">
            <div class="feature">
                
                <p class="feature-text">Private & Secure</p>
            </div>
            <div class="feature">
               
                <p class="feature-text">Fast & Minimal</p>
            </div>
            <div class="feature">
               
                <p class="feature-text">Stay Organized</p>
            </div>
        </div>
    </div>
</div>

<!-- Why Section -->
<section class="why-section">
    <h2 class="why-title">Why Tudu?</h2>
    <p class="why-text">
        Tudu is built for people who value simplicity, speed, and privacy.
        <br>No clutter. No distractions. Just your tasks, done right.
    </p>
</section>