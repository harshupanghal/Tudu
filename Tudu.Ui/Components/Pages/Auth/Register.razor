    //     uploadedFile = e.File;

    //     Generate unique filename
    //     var fileName = $"{Guid.NewGuid()}{Path.GetExtension(uploadedFile.Name)}";
    //     var savePath = Path.Combine(Env.WebRootPath, "uploads", fileName);

    //     Ensure uploads folder exists
    //     Directory.CreateDirectory(Path.GetDirectoryName(savePath)!);

    //     Save file
    //     using var stream = new FileStream(savePath, FileMode.Create);
    //     await uploadedFile.OpenReadStream(5 * 1024 * 1024).CopyToAsync(stream);

    //     Save relative path into model
    //     registerRequest.ProfilePicturePath = $"/uploads/{fileName}";
    // }
    
    
    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        try
        {
            var file = e.File;

            // Limit size (2 MB here)
            var resized = await file.RequestImageFileAsync(file.ContentType, 300, 300);
            var buffer = new byte[resized.Size];
            await resized.OpenReadStream(2_000_000).ReadAsync(buffer);

            // Convert to base64 for preview
            PreviewUrl = $"data:{file.ContentType};base64,{Convert.ToBase64String(buffer)}";

            // Save to wwwroot/uploads
            var fileName = $"{Guid.NewGuid()}{Path.GetExtension(file.Name)}";
            var savePath = Path.Combine(Env.WebRootPath, "uploads", fileName);

            await using var fs = new FileStream(savePath, FileMode.Create);
            await file.OpenReadStream(2_000_000).CopyToAsync(fs);

            // Save path in DB (example)
            registerRequest.ProfilePicturePath = $"/uploads/{fileName}";
        }
        catch (Exception ex)
        {
            Console.WriteLine("Image upload failed: " + ex.Message);
        }
    }
}
}